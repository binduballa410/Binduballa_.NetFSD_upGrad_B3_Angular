@model WebApplication7.Models.Movie

<div class="container mt-4">
    <h2 class="text-danger">Delete Movie</h2>
    <h3>Are you sure you want to delete this?</h3>
    
    <div class="card mt-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-2">Title</dt>
                <dd class="col-sm-10">@Model.Title</dd>

                <dt class="col-sm-2">Genre</dt>
                <dd class="col-sm-10">@Model.Genre</dd>

                <dt class="col-sm-2">Price</dt>
                <dd class="col-sm-10">$@Model.Price</dd>
                
                <dt class="col-sm-2">Rating</dt>
                <dd class="col-sm-10">@Model.Rating</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>